---
interface Props {
  tagline?: string;
  firstName?: string;
  lastName?: string;
  midChip?: string;
  location?: string;
  available?: string;
}

const {
  tagline = "Full-Stack Developer & Web Designer",
  firstName = "Alexander",
  lastName = "Smith",
  midChip = "Currently building WatchDeck",
  location = "Dubai, UAE",
  available = "Available June 2026",
} = Astro.props;

const taglineParts = tagline.split("&");
---

<main class="stage">
  <div class="stage__tag fade-up delay-1">
    <div class="stage__eyebrow">
      <span class="stage__eyebrow-num">01</span>
      <span class="stage__eyebrow-line"></span>
      <span>Folio · 2026</span>
    </div>
    <div class="stage__role">
      {
        taglineParts.map((part, i) => (
          <>
            {part}
            {i < taglineParts.length - 1 && <em>&amp;</em>}
          </>
        ))
      }
    </div>
    <div class="stage__role-sub">
      I work at the seam of design and engineering — turning considered ideas
      into smooth, surprising interfaces.
    </div>
  </div>

  <div class="stage__meta fade-up delay-2">
    <div class="stage__meta-row"><span>Based</span><span>{location}</span></div>
    <div class="stage__meta-row">
      <span>Stack</span><span>Astro · GSAP · Lenis</span>
    </div>
    <div class="stage__meta-row"><span>Status</span><span>{available}</span></div>
  </div>

  <div class="stage__name-wrap">
    <h1 class="stage__name" aria-label={`${firstName} ${lastName}`}>
      <span class="stage__name-row">
        <span class="stage__name-glyph">{firstName}</span>
      </span>
      <span class="stage__name-row">
        <span class="stage__name-glyph">{lastName}</span>
      </span>
    </h1>
  </div>

  <div class="stage__corner fade-up delay-3">
    <div class="stage__card" aria-hidden="true">
      <span class="stage__card-label">Featured</span>
    </div>
    <span class="stage__chip" aria-hidden="true">
      <span class="stage__chip-bullet"></span>
      {midChip}
      <svg
        class="stage__chip-arrow"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M7 17 17 7"></path>
        <path d="M7 7h10v10"></path>
      </svg>
    </span>
  </div>

  <div class="rail fade-up delay-4">
    <div class="rail__group">
      <span>Index</span>
      <span>01 / 04 — Hero</span>
    </div>
    <div class="rail__group">
      <span>Latest</span>
      <span>WatchDeck — case study</span>
    </div>
    <div class="rail__scroll">
      <span>Scroll to explore</span>
      <span class="rail__scroll-arrow">
        <svg
          width="10"
          height="10"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 5v14"></path>
          <path d="m19 12-7 7-7-7"></path>
        </svg>
      </span>
    </div>
  </div>
</main>

<style>
  /* ---------- Hero stage ---------- */
  .stage {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: grid;
    grid-template-rows: 1fr auto;
    padding: 120px clamp(20px, 4vw, 48px) 24px;
  }

  /* ---------- Top-left tag column ---------- */
  .stage__tag {
    position: absolute;
    top: 110px;
    left: clamp(20px, 4vw, 48px);
    max-width: 260px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    z-index: 3;
  }
  .stage__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--color-fg-3);
  }
  .stage__eyebrow-num {
    color: var(--color-fg-2);
  }
  .stage__eyebrow-line {
    width: 24px;
    height: 1px;
    background: var(--color-line-2);
  }
  .stage__role {
    font-size: 15px;
    font-weight: var(--w-medium);
    color: var(--color-fg-1);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .stage__role :global(em) {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: var(--w-regular);
    color: var(--color-accent-hover);
  }
  .stage__role-sub {
    font-size: 12px;
    color: var(--color-fg-3);
    line-height: 1.5;
    letter-spacing: -0.005em;
    max-width: 220px;
  }

  /* ---------- Top-right meta column ---------- */
  .stage__meta {
    position: absolute;
    top: 110px;
    right: clamp(20px, 4vw, 48px);
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-fg-3);
    z-index: 3;
  }
  .stage__meta-row {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }
  .stage__meta-row span:first-child {
    color: var(--color-fg-4);
  }
  .stage__meta-row span:last-child {
    color: var(--color-fg-2);
  }

  /* ---------- Wordmark wrap ---------- */
  .stage__name-wrap {
    align-self: end;
    width: 100%;
    position: relative;
    margin-top: auto;
  }

  /* ---------- Bottom-right corner stack (card + chip) ---------- */
  .stage__corner {
    position: absolute;
    right: clamp(20px, 4vw, 48px);
    /* Anchor above the rail (rail row + stage padding-bottom). */
    bottom: calc(24px + 35px + 32px);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 14px;
    z-index: 4;
    pointer-events: none;
  }
  .stage__corner > * {
    pointer-events: auto;
  }

  /* ---------- Featured card (placeholder) ---------- */
  .stage__card {
    position: relative;
    width: clamp(260px, 26vw, 360px);
    aspect-ratio: 16 / 9;
    background:
      linear-gradient(
        135deg,
        rgba(16, 185, 129, 0.06),
        transparent 55%
      ),
      var(--color-bg-1);
    border: 1px solid var(--color-line-2);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-2);
    overflow: hidden;
  }
  .stage__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--color-line-1) 1px, transparent 1px),
      linear-gradient(to bottom, var(--color-line-1) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      black 30%,
      transparent 90%
    );
    -webkit-mask-image: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      black 30%,
      transparent 90%
    );
    pointer-events: none;
  }
  .stage__card-label {
    position: absolute;
    top: 12px;
    left: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: var(--w-medium);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--color-fg-4);
  }

  /* ---------- Mid chip ---------- */
  .stage__chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: clamp(8px, 1vw, 14px) clamp(14px, 1.6vw, 22px);
    background: var(--color-bg-1);
    border: 1px solid var(--color-line-2);
    border-radius: var(--radius-3);
    box-shadow: var(--shadow-2);
    font-family: var(--font-mono);
    font-size: clamp(11px, 1vw, 14px);
    font-weight: var(--w-medium);
    color: var(--color-fg-2);
    letter-spacing: 0;
    text-transform: none;
    position: relative;
  }
  .stage__chip-bullet {
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
    box-shadow:
      0 0 0 3px var(--color-accent-soft),
      0 0 10px var(--color-accent-glow);
    flex-shrink: 0;
  }
  .stage__chip-arrow {
    width: 14px;
    height: 14px;
    color: var(--color-fg-3);
  }

  /* ---------- The wordmark ---------- */
  .stage__name {
    font-family: var(--font-sans);
    font-weight: var(--w-medium);
    font-size: clamp(72px, 16vw, 260px);
    line-height: 0.85;
    letter-spacing: -0.05em;
    margin: 0;
    color: var(--color-fg-1);
    text-wrap: nowrap;
    display: flex;
    flex-direction: column;
    gap: clamp(0px, 1vw, 8px);
    position: relative;
  }
  .stage__name-row {
    display: flex;
    align-items: baseline;
    gap: clamp(12px, 2vw, 28px);
    overflow: hidden;
  }
  .stage__name-glyph {
    background: linear-gradient(
      180deg,
      var(--color-fg-1) 60%,
      rgba(245, 245, 244, 0.55)
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    display: inline-block;
    transform: translateY(110%);
    animation: name-reveal 1100ms var(--ease-out) forwards;
  }
  .stage__name-row:nth-child(1) > * {
    animation-delay: 220ms;
  }
  .stage__name-row:nth-child(2) > * {
    animation-delay: 360ms;
  }
  @keyframes name-reveal {
    to {
      transform: translateY(0);
    }
  }

  /* ---------- Bottom rail ---------- */
  .rail {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
    padding-top: 18px;
    border-top: 1px solid var(--color-line-1);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-fg-3);
    text-transform: uppercase;
  }
  .rail__group {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .rail__group span:first-child {
    color: var(--color-fg-4);
  }
  .rail__scroll {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-fg-2);
  }
  .rail__scroll-arrow {
    width: 24px;
    height: 24px;
    border: 1px solid var(--color-line-2);
    border-radius: 50%;
    display: grid;
    place-items: center;
    animation: bob 2.4s var(--ease-in-out) infinite;
  }
  @keyframes bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(3px);
    }
  }

  /* ---------- Entrance fade-up ---------- */
  .fade-up {
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up 900ms var(--ease-out) forwards;
  }
  .fade-up.delay-1 {
    animation-delay: 80ms;
  }
  .fade-up.delay-2 {
    animation-delay: 200ms;
  }
  .fade-up.delay-3 {
    animation-delay: 360ms;
  }
  .fade-up.delay-4 {
    animation-delay: 540ms;
  }
  @keyframes fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---------- Reduced motion ---------- */
  @media (prefers-reduced-motion: reduce) {
    .fade-up,
    .stage__name-glyph {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .rail__scroll-arrow {
      animation: none;
    }
  }

  /* ---------- Light theme ---------- */
  :global(.theme-light) .stage__name-glyph {
    background: linear-gradient(
      180deg,
      var(--color-fg-1) 60%,
      rgba(11, 11, 13, 0.55)
    );
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .stage {
      padding-top: 100px;
    }
    .stage__tag,
    .stage__meta {
      position: static;
      max-width: none;
      text-align: left;
    }
    .stage__name-row {
      gap: 8px;
    }
    .stage__corner {
      position: static;
      align-items: flex-start;
      margin-top: 24px;
    }
  }
</style>
