---
// Standalone cursor design playground — does NOT use BaseLayout, so the
// site-wide cursor (if any) doesn't fight the prototype here.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cursor Playground</title>
    <style>
      @import "@fontsource-variable/geist";
      @import "@fontsource-variable/geist-mono";

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0b0b0d;
        --emerald: #10b981;
        --emerald-light: #34d399;
        --emerald-pale: #6ee7b7;
        --emerald-soft: rgba(16, 185, 129, 0.12);
        --fg: #f5f5f4;
        --fg-2: #b8b8b3;
        --fg-3: #7a7a75;
        --line: rgba(245, 245, 244, 0.08);
        --line-2: rgba(245, 245, 244, 0.16);
        --font-sans: "Geist Variable", ui-sans-serif, system-ui, sans-serif;
        --font-mono: "Geist Mono Variable", ui-monospace, monospace;
      }

      html, body { width: 100%; min-height: 100vh; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-sans);
        line-height: 1.5;
        letter-spacing: -0.005em;
      }

      .playground {
        max-width: 800px;
        margin: 0 auto;
        padding: 80px 32px 120px;
        display: grid;
        gap: 56px;
      }

      h1 { font-size: 32px; font-weight: 500; letter-spacing: -0.02em; margin-bottom: 12px; }
      h2 {
        font-family: var(--font-mono);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--fg-3);
        margin-bottom: 18px;
      }
      p { color: var(--fg-2); max-width: 56ch; }

      .stack { display: grid; gap: 14px; align-items: start; justify-items: start; }

      .pill, .plain-link, .plain-btn {
        font-family: var(--font-mono);
        font-size: 13px;
        font-weight: 500;
        padding: 10px 18px;
        border-radius: 999px;
        background: rgba(17, 17, 20, 0.6);
        border: 1px solid var(--line-2);
        color: var(--fg);
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }
      .pill:hover, .plain-link:hover, .plain-btn:hover { background: rgba(17, 17, 20, 0.9); }

      .pill-bullet {
        width: 8px;
        height: 8px;
        background: var(--emerald);
        border-radius: 50%;
        box-shadow: 0 0 0 3px var(--emerald-soft);
        flex-shrink: 0;
      }
      .arrow { width: 14px; height: 14px; color: var(--fg-3); }

      .big-target { padding: 14px 26px; font-size: 14px; }
      .tall-target {
        padding: 18px 22px;
        font-size: 12px;
        text-align: left;
        border-radius: 12px;
        max-width: 340px;
        line-height: 1.45;
        white-space: normal;
      }
      .card {
        padding: 22px;
        border-radius: 8px;
        background: rgba(17, 17, 20, 0.6);
        border: 1px solid var(--line-2);
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--fg-2);
        max-width: 380px;
        line-height: 1.5;
        text-decoration: none;
      }
      .card-label {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--fg-3);
        margin-bottom: 10px;
      }

      /* ── Custom cursor ─────────────────────────────────────────────────────
         Position-only outer; SVG inside re-rendered each frame with the
         current squiggle path. */
      .custom-cursor {
        position: fixed;
        top: var(--cursor-y, 50%);
        left: var(--cursor-x, 50%);
        width: var(--cursor-w, 80px);
        height: var(--cursor-h, 80px);
        transform: translate(-50%, -50%);
        opacity: var(--cursor-opacity, 1);
        pointer-events: none;
        z-index: 200;
      }

      .custom-cursor__svg {
        width: 100%;
        height: 100%;
        overflow: visible;
      }

      .custom-cursor__path {
        fill: none;
        stroke: rgba(110, 231, 183, 0.78);
        stroke-width: 2.75;
        stroke-linejoin: round;
        stroke-linecap: round;
        vector-effect: non-scaling-stroke;
      }

      @media (hover: none), (prefers-reduced-motion: reduce) {
        .custom-cursor { display: none; }
      }
    </style>
  </head>

  <body>
    <main class="playground">
      <header>
        <h1>Cursor playground</h1>
        <p>Move around to see the default squiggle — wave bumps travel clockwise around the outline (not the ring rotating). Hover the labelled "ring me" targets and the cursor will morph to wrap them with 4 px of breathing room. Hover the plain buttons / links and the cursor will vanish so you see the content cleanly.</p>
      </header>

      <section>
        <h2>Opt-in ring targets · cursor morphs to shape</h2>
        <div class="stack">
          <button class="pill" data-cursor-ring>
            <span class="pill-bullet"></span>
            Currently building WatchDeck
            <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17 17 7"></path>
              <path d="M7 7h10v10"></path>
            </svg>
          </button>
          <button class="pill big-target" data-cursor-ring>A wider opt-in pill target</button>
          <button class="pill tall-target" data-cursor-ring>A taller opt-in target with more padding inside its rounded border</button>
          <a href="#" class="card" data-cursor-ring>
            <div class="card-label">Featured · case study</div>
            A large rounded-rect card target — the cursor should wrap this whole shape with 4 px of breathing room when you hover it.
          </a>
        </div>
      </section>

      <section>
        <h2>Plain interactive · cursor vanishes</h2>
        <div class="stack">
          <button class="plain-btn">Plain button (cursor should vanish)</button>
          <a href="#" class="plain-link">Plain link →</a>
        </div>
      </section>

      <section>
        <h2>Plain content · cursor stays default circle</h2>
        <div class="stack">
          <p>Just paragraph text. The cursor squiggle stays a circle here, with the wave bumps visibly travelling around the outline like a snake winding around itself.</p>
        </div>
      </section>
    </main>

    <div class="custom-cursor" aria-hidden="true">
      <svg class="custom-cursor__svg" aria-hidden="true">
        <path class="custom-cursor__path"></path>
      </svg>
    </div>

    <script>
      // Squiggle cursor — single parametric path that handles both circle and
      // rounded-rect shapes. Each frame the sin phase advances so wave bumps
      // physically travel along the outline (not just SVG rotation).

      type PerimeterPoint = { x: number; y: number; nx: number; ny: number };

      // Walk the perimeter of a centered rounded rect (W × H, corner radius r),
      // clockwise starting at top-center, returning the point and outward
      // unit normal at fraction t ∈ [0, 1].
      function roundedRectPerimeterPoint(t: number, W: number, H: number, r: number): PerimeterPoint {
        const cR = Math.min(r, Math.min(W, H) / 2);
        const sw = Math.max(0, W - 2 * cR);
        const sh = Math.max(0, H - 2 * cR);
        const arc = (Math.PI * cR) / 2;
        const total = 2 * sw + 2 * sh + 4 * arc;

        if (total <= 0.001) return { x: 0, y: 0, nx: 0, ny: -1 };

        let s = ((t % 1) + 1) % 1 * total;

        // 1: top straight (right half), top-center → top-right corner start
        if (s < sw / 2) return { x: s, y: -H / 2, nx: 0, ny: -1 };
        s -= sw / 2;

        // 2: top-right corner arc
        if (s < arc) {
          const a = (s / arc) * (Math.PI / 2);
          return {
            x: W / 2 - cR + cR * Math.sin(a),
            y: -H / 2 + cR - cR * Math.cos(a),
            nx: Math.sin(a),
            ny: -Math.cos(a),
          };
        }
        s -= arc;

        // 3: right straight, top → bottom
        if (s < sh) return { x: W / 2, y: -H / 2 + cR + s, nx: 1, ny: 0 };
        s -= sh;

        // 4: bottom-right corner arc
        if (s < arc) {
          const a = (s / arc) * (Math.PI / 2);
          return {
            x: W / 2 - cR + cR * Math.cos(a),
            y: H / 2 - cR + cR * Math.sin(a),
            nx: Math.cos(a),
            ny: Math.sin(a),
          };
        }
        s -= arc;

        // 5: bottom straight, right → left
        if (s < sw) return { x: W / 2 - cR - s, y: H / 2, nx: 0, ny: 1 };
        s -= sw;

        // 6: bottom-left corner arc
        if (s < arc) {
          const a = (s / arc) * (Math.PI / 2);
          return {
            x: -W / 2 + cR - cR * Math.sin(a),
            y: H / 2 - cR + cR * Math.cos(a),
            nx: -Math.sin(a),
            ny: Math.cos(a),
          };
        }
        s -= arc;

        // 7: left straight, bottom → top
        if (s < sh) return { x: -W / 2, y: H / 2 - cR - s, nx: -1, ny: 0 };
        s -= sh;

        // 8: top-left corner arc
        if (s < arc) {
          const a = (s / arc) * (Math.PI / 2);
          return {
            x: -W / 2 + cR - cR * Math.cos(a),
            y: -H / 2 + cR - cR * Math.sin(a),
            nx: -Math.cos(a),
            ny: -Math.sin(a),
          };
        }
        s -= arc;

        // 9: top straight (left half), top-left corner end → top-center
        return { x: -sw / 2 + s, y: -H / 2, nx: 0, ny: -1 };
      }

      // Total perimeter length for a centered rounded rect (W × H, corner r).
      function roundedRectPerimeter(W: number, H: number, r: number): number {
        const cR = Math.min(r, Math.min(W, H) / 2);
        const sw = Math.max(0, W - 2 * cR);
        const sh = Math.max(0, H - 2 * cR);
        const arc = (Math.PI * cR) / 2;
        return 2 * sw + 2 * sh + 4 * arc;
      }

      // Build the squiggle path: at each sample, displace the perimeter point
      // outward along its normal by A·sin(N·t·2π + phase). Phase advances
      // each frame so the bumps slide along the outline.
      function squiggleAroundShape(
        W: number, H: number, r: number,
        A: number, N: number, samples: number,
        phase: number
      ): string {
        let d = "";
        for (let i = 0; i <= samples; i++) {
          const t = i / samples;
          const { x, y, nx, ny } = roundedRectPerimeterPoint(t, W, H, r);
          const offset = A * Math.sin(N * t * 2 * Math.PI + phase);
          const px = (x + nx * offset).toFixed(2);
          const py = (y + ny * offset).toFixed(2);
          d += i === 0 ? `M${px} ${py}` : `L${px} ${py}`;
        }
        return d + "Z";
      }

      // ── Setup ──
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const hasHover = window.matchMedia("(hover: hover)").matches;

      if (hasHover && !reducedMotion) {
        const cursor = document.querySelector<HTMLElement>(".custom-cursor");
        const pathEl = document.querySelector<SVGPathElement>(".custom-cursor__path");
        const svgEl  = document.querySelector<SVGElement>(".custom-cursor__svg");

        if (cursor && pathEl && svgEl) {
          // Tunable knobs
          const DEFAULT_D       = 56;     // default circle diameter
          const RING_PADDING    = 4;      // space between target and squiggles
          const RING_CORNER_R   = 10;     // corner radius when wrapping a target
          const WAVE_AMPLITUDE  = 2;      // outward sin amplitude (px)
          const WAVE_WAVELENGTH = 22;     // target px between bumps — wave count
                                          // is derived from the current perimeter so
                                          // bumps stay visually the same size whether
                                          // wrapped around a small circle or a wide button
          const SAMPLES         = 192;    // path resolution
          const PHASE_RATE      = 0.07;   // rad/frame — wave travel speed (slow, subtle)
          const POS_RATE        = 0.05;   // matches threads bg lerp
          const RING_POS_RATE   = 0.20;   // faster snap onto a ring target
          const SHAPE_RATE      = 0.16;
          const VISIBILITY_RATE = 0.025;  // how fast the line wipes in/out — slower for clearly-visible animation

          // State
          let rawX  = window.innerWidth  / 2;
          let rawY  = window.innerHeight / 2;
          let lerpX = rawX;
          let lerpY = rawY;
          let curW  = DEFAULT_D;
          let curH  = DEFAULT_D;
          let curR  = DEFAULT_D / 2;
          let curVisible = 1;   // 0..1 — fraction of perimeter currently drawn
          let phase = 0;

          type Mode = "default" | "hidden" | "ring";
          let mode: Mode = "default";
          let ringEl: Element | null = null;

          window.addEventListener("mousemove", (e) => {
            rawX = e.clientX;
            rawY = e.clientY;
          }, { passive: true });

          function updateModeFromTarget(target: Element | null): { mode: Mode; el: Element | null } {
            if (!target) return { mode: "default", el: null };
            const ring = target.closest("[data-cursor-ring]");
            if (ring) return { mode: "ring", el: ring };
            const interactive = target.closest("a, button");
            if (interactive) return { mode: "hidden", el: null };
            return { mode: "default", el: null };
          }

          document.addEventListener("mouseover", (e) => {
            const result = updateModeFromTarget(e.target as Element);
            mode = result.mode;
            ringEl = result.el;
          });

          document.addEventListener("mouseout", (e) => {
            const result = updateModeFromTarget(e.relatedTarget as Element | null);
            mode = result.mode;
            ringEl = result.el;
          });

          function tick(): void {
            // Defensive: ring target removed from DOM
            if (mode === "ring" && (!ringEl || !document.contains(ringEl))) {
              mode = "default";
              ringEl = null;
            }

            let targetX: number, targetY: number;
            let targetW: number, targetH: number, targetR: number;
            let targetVisible: number, posRate: number;

            if (mode === "ring" && ringEl) {
              const rect = ringEl.getBoundingClientRect();
              targetX = rect.left + rect.width  / 2;
              targetY = rect.top  + rect.height / 2;
              targetW = rect.width  + 2 * RING_PADDING;
              targetH = rect.height + 2 * RING_PADDING;
              targetR = RING_CORNER_R;
              targetVisible = 1;
              posRate = RING_POS_RATE;
            } else if (mode === "hidden") {
              targetX = rawX; targetY = rawY;
              targetW = DEFAULT_D; targetH = DEFAULT_D;
              targetR = DEFAULT_D / 2;
              targetVisible = 0;
              posRate = POS_RATE;
            } else {
              targetX = rawX; targetY = rawY;
              targetW = DEFAULT_D; targetH = DEFAULT_D;
              targetR = DEFAULT_D / 2;
              targetVisible = 1;
              posRate = POS_RATE;
            }

            lerpX += (targetX - lerpX) * posRate;
            lerpY += (targetY - lerpY) * posRate;
            curW  += (targetW - curW)  * SHAPE_RATE;
            curH  += (targetH - curH)  * SHAPE_RATE;
            curR  += (targetR - curR)  * SHAPE_RATE;
            curVisible += (targetVisible - curVisible) * VISIBILITY_RATE;

            phase += PHASE_RATE;

            // Box has extra margin so the wave amplitude doesn't get clipped
            const margin = WAVE_AMPLITUDE * 4;
            const boxW = curW + margin;
            const boxH = curH + margin;

            cursor!.style.setProperty("--cursor-x", `${lerpX.toFixed(2)}px`);
            cursor!.style.setProperty("--cursor-y", `${lerpY.toFixed(2)}px`);
            cursor!.style.setProperty("--cursor-w", `${boxW.toFixed(2)}px`);
            cursor!.style.setProperty("--cursor-h", `${boxH.toFixed(2)}px`);

            svgEl!.setAttribute(
              "viewBox",
              `${(-boxW / 2).toFixed(2)} ${(-boxH / 2).toFixed(2)} ${boxW.toFixed(2)} ${boxH.toFixed(2)}`
            );

            // Wave count from the current perimeter so bump spacing stays
            // visually constant across shapes. Round to keep the sin wave
            // closed (no kink at top-center where the path joins itself).
            const perimeter = roundedRectPerimeter(curW, curH, curR);
            const waveCount = Math.max(4, Math.round(perimeter / WAVE_WAVELENGTH));

            pathEl!.setAttribute(
              "d",
              squiggleAroundShape(curW, curH, curR, WAVE_AMPLITUDE, waveCount, SAMPLES, phase)
            );

            // Progress-circle vanish: stroke-dasharray = total path length,
            // stroke-dashoffset lerps from 0 (fully drawn) to length (erased).
            // The line wipes around the perimeter starting from top-center.
            const totalLen = pathEl!.getTotalLength();
            const offset = (1 - Math.max(0, Math.min(1, curVisible))) * totalLen;
            pathEl!.style.strokeDasharray = `${totalLen.toFixed(2)}`;
            pathEl!.style.strokeDashoffset = `${offset.toFixed(2)}`;

            requestAnimationFrame(tick);
          }

          requestAnimationFrame(tick);
        }
      }
    </script>
  </body>
</html>
